<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.DrugDose" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:windowBackground">@color/neutral</item>
    </style>

    <style name="Widget.DrugDose.TextInputLayout.base" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/grey</item>
        <item name="android:textColor">@color/grey</item>
        <item name="errorTextColor">@color/error_red</item>
    </style>

    <style name="Widget.DrugDose.button.BottonePrimario" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="TextAppearance.DrugDose.NomeApp" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:text">@string/app_name</item>
    </style>

    <style name="TextAppearance.DrugDose.Slogan" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:text">Clinical dosing precision</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.DrugDose.Ospite" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.DrugDose.Button.Ospite" parent="Widget.Material3.Button.TextButton">
        <item name="android:drawableLeft">@drawable/icon_person</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textAppearance">@style/TextAppearance.DrugDose.Ospite</item>
    </style>

    <style name="TextAppearance.DrugDose.bottoneSecondario" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.DrugDose.Button.bottoneSecondario" parent="Widget.Material3.Button.TextButton">
        <item name="android:drawablePadding">4dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.DrugDose.Link" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.DrugDose.TextView.Link" parent="android:Widget.TextView">
        <item name="android:textAppearance">@style/TextAppearance.DrugDose.Link</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:padding">2dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.DrugDose.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">@color/neutral</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/border_color</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Theme.DrugDose" parent="Base.Theme.DrugDose" />



</resources>